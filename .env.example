SECRET_KEY=change-this-to-a-long-random-secret
SUPER_ADMIN_EMAIL=admin@grain.local
SUPER_ADMIN_PASSWORD=change-this-admin-password
DATA_DIR=./data
COOKIE_SECURE=false
PERSON_RETRIEVER_BACKEND=grain
GENERAL_RETRIEVER_BACKEND=openclip
GENERAL_OPENCLIP_MODEL=ViT-B-16
GENERAL_OPENCLIP_PRETRAINED=laion2b_s34b_b88k
TRANSLATION_BACKEND=transformers
TRANSLATION_MODEL_NAME=Helsinki-NLP/opus-mt-zh-en
TRANSLATION_DEVICE=cpu
TRANSLATION_MAX_NEW_TOKENS=96
TRANSLATION_NUM_BEAMS=4
GRAIN_CONFIG_FILE=/absolute/path/to/configs.yaml
GRAIN_CHECKPOINT=/absolute/path/to/best_map.pth
ALLOW_RETRIEVER_FALLBACK=true
INVITE_BOOTSTRAP_CODES=GRAIN-DEMO-2026
